{
  "name": "zero-snippets",
  "version": "1.0.0",
  "description": "An Electron application with Vue and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts,.vue --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bytemd/plugin-breaks": "^1.22.0",
    "@bytemd/plugin-frontmatter": "^1.22.0",
    "@bytemd/plugin-gemoji": "^1.22.0",
    "@bytemd/plugin-gfm": "^1.22.0",
    "@bytemd/plugin-highlight": "^1.22.0",
    "@bytemd/plugin-math": "^1.22.0",
    "@bytemd/plugin-medium-zoom": "^1.22.0",
    "@bytemd/plugin-mermaid": "^1.22.0",
    "@bytemd/vue-next": "^1.22.0",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@imengyu/vue3-context-menu": "^1.5.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mockjs": "^1.0.10",
    "ali-oss": "^6.23.0",
    "ant-design-vue": "^4.2.6",
    "better-sqlite3": "^12.2.0",
    "bytemd": "^1.22.0",
    "bytemd-plugin-highlight": "^1.0.0",
    "bytemd-plugin-theme": "^1.0.2",
    "cheerio": "^1.2.0",
    "electron-updater": "^6.1.7",
    "highlight.js": "^11.11.1",
    "juejin-markdown-themes": "^1.34.0",
    "mockjs": "^1.1.0",
    "pinia": "^3.0.3",
    "sass": "^1.89.2",
    "scss": "^0.2.4",
    "tailwindcss": "3.4.16",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^1.0.2",
    "@electron-toolkit/eslint-config-ts": "^1.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@rushstack/eslint-patch": "^1.7.1",
    "@types/cheerio": "^1.0.0",
    "@types/node": "^18.19.9",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "autoprefixer": "^10.4.21",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "jsdom": "^24.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^1.3.1",
    "vue": "^3.4.15",
    "vue-tsc": "^1.8.27"
  }
}
